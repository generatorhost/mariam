{
  "policy_id": "db-mariam-backup-policy-v1",
  "data_platform": "DB MARIAM",
  "version": "0.1.0",
  "status": "ready_for_review",
  "scope": [
    "Runtime DB",
    "Mission DB",
    "Audit DB",
    "Governance DB",
    "CRM DB",
    "Scraping DB",
    "Opportunity DB",
    "Communication DB",
    "Document DB",
    "DNA Registry DB",
    "Capability Graph DB",
    "Workflow DB",
    "Object Storage",
    "Vector Store",
    "Logs Store",
    "Metrics Store",
    "Artifact Store"
  ],
  "rules": {
    "contains_secrets": false,
    "no_plaintext_credentials": true,
    "encryption_required": true,
    "restore_test_required": true,
